# ─── App Config ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and should NEVER be committed.

# ─── Server / Sync (optional — app works fully offline without these) ─────────
# AWS_API_ENDPOINT=https://your-api-gateway-url.execute-api.ap-south-1.amazonaws.com
# AWS_S3_BUCKET=your-biometric-bucket
# AWS_REGION=ap-south-1

# ─── App Settings ────────────────────────────────────────────────────────────
# FACE_MATCH_THRESHOLD=0.92
# LIVENESS_FRAME_COUNT=10
